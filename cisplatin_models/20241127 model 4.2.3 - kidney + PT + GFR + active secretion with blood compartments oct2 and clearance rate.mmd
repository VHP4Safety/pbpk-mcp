<size>14</size><family>SansSerif</family><bold>{human PBK model with kidney + proximal tubule, glomerular filtration + active secretion} </bold>

STARTTIME = 0			;start time in hours
STOPTIME = 48			;stop time in hours
DT = 0.01

<bold><italic>{model compartments}</bold></italic>
;arterial blood		AB
;venous blood		VB
;fat			F
;slowly perfused tissue		S
;richly perfused tissue		R
;kidney blood		KB
;rest of kidney 		RK
;proximal tubule		PT
;urine			UR
;glomerular filtration		GF or GFR


<bold><italic>{physiological parameters}</bold></italic>
;from Brown 1997, Maass 2019, Valetin 2022

BW = 70			;body weight in kg
QFC = 0.05		;fractional blood flow to fat tissue, unitless (/kg BW)
QSC = 0.27		;fractional blood flow to slowly perfused tissue, unitless (/kg BW)
QRC = 0.49		;fractional blood flow to richly perfused tissue, unitless (/kg BW)
QKBC = 0.19		;fractional blood flow to arterial kidney blood, unitless (/kg BW)

VBC = 0.0771		;fractional volume of arterial blood in L/kg BW
VFC = 0.2142		;fractional volume of fat in L/kg BW
VSC = 0.58		;fractional volume of slowly perfused tissue in L/kg BW
VRC = 0.1243		;fractional volume of richly perfused tissue in L/kg BW
VKBC = 0.18*0.0044		;fractional volume of arterial kidney blood in L/kg BW
VRKC = 0.21*0.0044		;fractional volume of rest of kidney in L/kg BW
VPTC = 0.28*0.0044		;fractional volume of proximal tubule in L/kg BW
VFILC = 0.33*0.0044		;fractional volume of filtrate in L/kg BW
VTKC = 0.0044		;fractional volume of total kidney in L/kg BW


<bold><italic>{calculated physiological parameters} </bold></italic>

QC = 15*(BW^0.74)	;cardiac output in L/h (Brown 1997)
QF = QFC*QC		;blood flow to fat tissue in L/h
QS = QSC*QC		;blood flow to slowly perfused tissue in L/h
QR = QRC*QC		;blood flow to richly perfused tissue in L/h
QKB = QKBC*QC		;blood flow to kidney blood in L/h

VB = VBC*BW		;volume arterial blood in L
VF = VFC*BW		;volume fat tissue in L
VS = VSC*BW		;volume slowly perfused tissue in L
VR = VRC*BW		;volume richly perfused tissue in L
VKB = VKBC*BW		;volume arterial kidney blood in L
VRK = VRKC*BW		;volume rest of kidney in L
VPT = VPTC*BW		;volume of proximal tubule in L
VFIL = VFILC*BW		;volume of filtrate in L


<bold><italic>{physicochemical parameters cisplatin}</bold></italic>

PF =  0.0605 	;blood to fat partition coefficient, unitless
PS = 0.2512 	;blood to slowly perfused tissue partition coefficient, unitless
PR = 0.2678 	;blood to richtly perfused tissue  partition coefficient, unitless
PRK = 0.2698 	;blood to rest of kidney partition coefficient, unitless
MW = 300.5	;molecular weight in g/mol

<bold><italic>{kinetic parameters}</bold></italic>

<bold><underline>{absorption of cisplatin}</bold></underline>
	;administration of cisplatin: intravenous
	;absorption is 100% or 1

IVDOSEM2 = 80				;IV dose in mg/m2 surface area
IVDOSEMG =( IVDOSEM2*1.78)/BW 		;IV dose in mg/kg BW
IVDOSEUMOL = IVDOSEMG*1E-3/MW*1E6 		;IV dose in umol/kg BW
IVDOSE = IVDOSEUMOL*BW			;given IV dose in umol

<bold><underline>{needle compartment}</bold></underline>
	{ANEEDLE = amount in needle in umol}
	{ANEEDLE' = infusion rate}

ANEEDLE' = -kn*ANEEDLE
Init ANEEDLE = IVDOSE
kn = 10000


<bold><italic>{model equations}</bold></italic>

<bold><underline>{fat compartment}</bold></underline>
	{AF = amount cisplatin in fat in umol} 
	{AF' = rate of change amount cisplatin in fat}

AF' = QF*(CB-CVF)		;rate of change amount in umol/h
Init AF = 0			;inital amount in fat in umol
CF = AF/VF		;concentration cisplatin in fat in umol/L
CVF = CF/PF		;concentration in fat venous blood in umol/L

<bold>
<underline>{slowly perfused tissue compartment}</bold></underline>
	{AS = amount cisplatin in slowly perfused tissue in umol} 
	{AS' = rate of change amount cisplatin in slowly perfused tissue}

AS' = QS*(CB-CVS)		;rate of change amount in umol/h
Init AS = 0			;inital amount in slowly perfused tissue in umol
CS = AS/VS		;concentration cisplatin in slowly perfused tissue in umol/L
CVS = CS/PS		;concentration in slowly perfused tissue venous blood in umol/L

<bold>
<underline>{richtly perfused tissue compartment}</bold></underline>
	{AR = amount cisplatin in richly perfused tissue in umol} 
	{AR' = rate of change amount cisplatin in richly perfused tissue}

AR' = QR*(CB-CVR)		;rate of change amount in umol/h
Init AR = 0			;inital amount in richly perfused tissue in umol
CR = AR/VR		;concentration cisplatin in richly perfused tissue in umol/L
CVR = CR/PR		;concentration in richly perfused tissue venous blood in umol/L


<bold><underline>{kidney compartment}</bold></underline>
	{AKB = amount cisplatin in arterial kidney blood in umol} 
	{AAKB' = rate of change amount cisplatin in arterial kidney blood}
	{ARK = amount cisplatin in rest of kidney in umol} 
	{ARK' = rate of change amount cisplatin in rest of kidney}

AKB' = QKB*(CB) - (QKB*CKB)  - GF' - AOCT'	
			;rate of change in kidney blood in umol/h
Init AKB = 0		;initial amount in kidney blood in umol
CKB = AKB/VKB		;concentration kidney blood in umol/L

ARK' = QKB*(CKB-CVRK) 	;rate of change amount in umol/h
Init ARK = 0		;inital amount in rest of kidney in umol
CRK = ARK/VRK		;concentration cisplatin in rest of kidney in umol/L
CVRK = CRK/PRK 		;concentration in rest of kidney venous blood in umol/L


<bold><underline>{proximal tubule compartment}	</bold>
</underline>	{APT = amount cisplatin in proximal tubule in umol} 
	{APT' = rate of change amount cisplatin in proximal tubule in umol/h}
	{AFIL = amount cisplatin in filtrate in umol} 
	{AFIL' = rate of change amount cisplatin in filtrate}

APT' = AOCT' - AMATE'  	;rate of change amount in umol/h
Init APT = 0 		;initial amount in proximal tubule in umol
CPT = APT/VPT		;concentration cisplatin in proximal tubule in umol/L


MK = VTKC*BW*1000		;mass total kidney in gram
PTC = 6E7			;number of pt cells per gram kidney
PTPROTEIN = 2.0e-9		;gram protein/proximal tubule cell
MPT = MK*PTC*PTPROTEIN	;mass proximal tubule in gram based on BW


AMATE' = CLMATE*CPT 	;clearance rate of active transport from proximal tubule into filtrate in umol/h
Init AMATE = 0		;initial amount efflux
CLMATE = (VmaxOCTc/KmOCT)*60*MPT*5*SFMATE/1000
SFMATE = 0.06		;scaling factor MATEs 
;VmaxMATEc =  13.7		;Vmax in pmol/mg/min (from Sprowl 2013)
;VmaxMATE = (VmaxMATEc/1000000)*60*MPT*1000*SFMATE	;Vmax in umol/h, maximum rate of efflux cisplatin by MATE
;KmMATE = 11.4 		;Km in umol/L, transport constant of cisplatin by MATE<bold><italic>
</bold></italic>

AOCT' =   (VmaxOCT*(CKB*(Fup/BPR))) / (KmOCT+(CKB*(Fup/BPR))) ;rate of active transport from kidney blood into proximal tubule in umol/h
Init AOCT = 0		;initital amount diffused from blood to proximal tubule in umol
SFOCT = 35		;scaling factor OCT2 
PEROCT = 1
VmaxOCTc =  13.7 		;Vmax in pmol/mg/min (from Sprowl 2013)
VmaxOCT = (VmaxOCTc/1000000)*60*MPT*1000*SFOCT*PEROCT	
			;Vmax in umol/h, maximum rate of uptake cisplatin by OCT2
KmOCT = 11.4 		;Km in umol/L, transport constant of cisplatin by OCT2 (from Sprowl 2013)


<bold><underline>{filtrate + urine compartment}</bold></underline>

AFIL' = GF' + AMATE' - AUR'	;rate of change amount in filtrate in umol/h
Init AFIL = 0		;initial amount in filtrate in umol
CFIL = AFIL/VFIL		;concentration in filtrate
AUR' = CFIL*kur		;clearance rate to urine (umol/h)
init AUR = 0
kUR = 0.083		;rate in L/h (based on standard urine production in 83 ml/h)
CUR = AUR/VUR		;concentration in urine
VUR = kUR*STOPTIME



<bold><underline>{blood compartment}</bold></underline>
	{AB = amount cisplatin in blood in umol}
	{AB' = rate of change amount cisplatin in blood}

AB' = (kn*ANEEDLE + QF*CVF + QS*CVS + QR*CVR + QKB*CVRK) - (QF + QS + QR + QKB)*CB
Init AB = 0		;initial amount amount in arterial blood
CB = AB/VB             	;concentration in arterial blood in umol
CP = (CB/BPR)*Fup	;concentration in plasma in umol


Fup = 0.8                       	;fraction unbound cisplatin in plasma
Futpt = Fub*PRK		;fraction unbound cisplatin in kidney tissue
Pptp = 0.58		;proximal tubule to plasma partition coefficient
BPR = 2.15		;blood plasma ratio
Fub = 1/(0.55*((1/Fup)-1)+1)	;fraction unbound cisplatin in blood
GFR = 0.1071 * BW             	;glomerular filtration rate human in L/h
GF' = (CKB*GFR*(Fup/BPR))		;glomerular filtration cisplatin umol/h
Init GF = 0			;initial amount filtrered


<bold><italic>{mass balance}</bold></italic>

TOTAL = IVDOSE
CALCULATED = AB + AF + AS + AR + AKB + AFIL + ARK + APT + AUR + ANEEDLE 
ERROR = ((TOTAL-CALCULATED)/TOTAL)*100
MASSBALANCE = TOTAL-CALCULATED+1

CPTA' = APT'/VPT
init CPTA = 0
AUCPT' = CPT + CPTA'
init AUCPT = 0
AUC' = CPT		;AUC proximal tubule concentration
init AUC = 0		;initial AUC
AUCP'= CP			;AUC plasma concentration
init AUCP = 0		;initial AUC
AUCKB' = CKB		;AUC arterial kidney blood concentration
Init AUCKB = 0		;initial AUC



